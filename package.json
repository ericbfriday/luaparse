{
  "name": "luaparse",
  "version": "2.0.0",
  "description": "A Lua parser in JavaScript with unist-compatible AST output",
  "keywords": [
    "ast",
    "lua",
    "luast",
    "parser",
    "parsing",
    "unist",
    "syntax-tree",
    "unified"
  ],
  "homepage": "https://fstirlitz.github.io/luaparse/",
  "bugs": "https://github.com/fstirlitz/luaparse/issues",
  "license": "MIT",
  "author": "Oskar Schöldström <public@oxy.fi> (http://www.oxy.fi/)",
  "files": [
    "README.md",
    "LICENSE",
    "luaparse.js",
    "luaparse.mjs",
    "luaparse.d.ts",
    "bin/luaparse"
  ],
  "main": "luaparse.js",
  "types": "luaparse.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./luaparse.d.ts",
        "default": "./luaparse.mjs"
      },
      "require": {
        "types": "./luaparse.d.ts",
        "default": "./luaparse.js"
      }
    }
  },
  "bin": {
    "luaparse": "bin/luaparse"
  },
  "man": "./docs/luaparse.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/fstirlitz/luaparse.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node test/runner.js --console",
    "test:packages": "for d in packages/*/; do (cd \"$d\" && npx vitest run); done"
  },
  "devDependencies": {
    "benchmark": "~1.0.0",
    "spec": "1.0.1"
  }
}
