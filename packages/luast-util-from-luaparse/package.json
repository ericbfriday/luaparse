{
  "name": "@friday-friday/luast-util-from-luaparse",
  "version": "0.2.0",
  "description": "Convert legacy luaparse AST to luast format",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build --clean && tsc --build",
    "format": "prettier . -w --log-level warn && xo --fix",
    "test-api": "vitest run",
    "test": "npm run build && npm run format && npm run test-api"
  },
  "dependencies": {
    "@friday-friday/luast": "file:../luast"
  },
  "devDependencies": {
    "@friday-friday/luaparse": "file:../../",
    "@friday-friday/luast-util-visit": "file:../luast-util-visit",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "unist-util-position": "^5.0.0",
    "vitest": "^3.0.0",
    "xo": "^0.60.0"
  },
  "prettier": {
    "bracketSpacing": false,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": false
  },
  "xo": {
    "prettier": true,
    "rules": {
      "@typescript-eslint/naming-convention": "off"
    },
    "overrides": [
      {
        "files": "test/**",
        "rules": {
          "@typescript-eslint/consistent-type-assertions": "off",
          "@typescript-eslint/no-unsafe-member-access": "off",
          "@typescript-eslint/no-unsafe-assignment": "off",
          "unicorn/prefer-structured-clone": "off"
        }
      }
    ]
  }
}
