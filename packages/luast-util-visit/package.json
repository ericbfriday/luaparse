{
  "name": "@friday-friday/luast-util-visit",
  "version": "0.3.0",
  "description": "Tree visitor for luast (named-field aware) — walk Lua ASTs using the child-field registry",
  "author": "Eric Friday <ericfriday@gmail.com>",
  "license": "MIT",
  "keywords": [
    "lua",
    "luast",
    "ast",
    "unist",
    "visitor",
    "walk",
    "traverse",
    "syntax-tree"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ericbfriday/luaparse.git",
    "directory": "packages/luast-util-visit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build --clean && tsc --build",
    "format": "prettier . -w --log-level warn && xo --fix",
    "test-api": "vitest run",
    "test": "npm run build && npm run format && npm run test-api"
  },
  "dependencies": {
    "@friday-friday/luast": "^0.3.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "xo": "^0.60.0"
  },
  "prettier": {
    "bracketSpacing": false,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": false
  },
  "xo": {
    "prettier": true,
    "rules": {
      "@typescript-eslint/naming-convention": [
        "error",
        {
          "selector": "variable",
          "format": ["strictCamelCase"],
          "filter": {
            "regex": "^(SKIP|REMOVE|EXIT)$",
            "match": false
          }
        }
      ]
    },
    "overrides": [
      {
        "files": "test/**",
        "rules": {
          "@typescript-eslint/consistent-type-assertions": "off",
          "@typescript-eslint/naming-convention": "off"
        }
      }
    ]
  }
}
