{
  "name": "luast",
  "version": "0.1.0",
  "description": "Lua Abstract Syntax Tree format — unist-compliant tree specification and TypeScript types",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build --clean && tsc --build",
    "format": "prettier . -w --log-level warn && xo --fix",
    "test-api": "vitest run",
    "test": "npm run build && npm run format && npm run test-api"
  },
  "dependencies": {
    "@types/unist": "^3.0.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "unist-util-is": "^6.0.0",
    "unist-util-position": "^5.0.0",
    "vitest": "^3.0.0",
    "xo": "^0.60.0"
  },
  "prettier": {
    "bracketSpacing": false,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": false
  },
  "xo": {
    "prettier": true
  }
}
