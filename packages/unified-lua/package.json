{
  "name": "unified-lua",
  "version": "0.1.0",
  "description": "unified parser plugin for Lua — produces luast syntax trees",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
